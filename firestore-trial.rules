rules_version = '2';
// Rules KHUSUS project Firebase "myosigid" — jalur uji coba Tumara
// (register.html / pilih-pekerjaan.html / coba-app.html).
// Terpisah dari firestore.rules (project sekolah tumara-id).
service cloud.firestore {
  match /databases/{database}/documents {
    match /trial_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subkoleksi data aplikasi (health_daily, notes, tasks, transactions, dst.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
