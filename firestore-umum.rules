rules_version = '2';
// Rules KHUSUS project Firebase "myosigid" — jalur Umum Tumara, untuk
// orang di luar sekolah yang tak ada sangkut-paut dengan akun sekolah
// (register.html / pilih-pekerjaan.html / data-diri.html / umum-app.html).
// Terpisah dari firestore.rules (project sekolah tumara-id).
//
// Koleksi Firestore-nya "users" (sejak 2026-07-18; sebelumnya "trial_users"
// — lihat scripts/migrate-trial-users.js untuk migrasi akun lama). Path
// /trial_users di bawah SENGAJA dibiarkan aktif untuk sementara sebagai
// jaring pengaman kalau ada klien lama (cache/PWA belum refresh) yang masih
// menulis ke path lama — hapus blok itu setelah dipastikan tak ada trafik
// lagi ke /trial_users (cek Firestore usage di console).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subkoleksi data aplikasi (health_daily, notes, tasks, transactions, dst.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Jaring pengaman sementara — lihat catatan di atas.
    match /trial_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
